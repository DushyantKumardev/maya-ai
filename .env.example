MONGODB_URI=mongodb://localhost:27017/maya-ai

# Security (AES-256-GCM)
MAYA_ENCRYPTION_KEY=please_add_your_encription_key_here

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth.js (NextAuth v5)
AUTH_SECRET=change_me_to_yours
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# Environment 
NODE_ENV=development
NEXT_PUBLIC_APP_MODE=self-hosted # Options: 'self-hosted' (local disk storage) or 'cloud' (Cloudinary, recommended for Vercel Hosting)

# Cloudinary Cloud Storage (required for Vercel cloud deployment)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Email Configuration 
# Option A: SMTP Server (e.g. Gmail App Password, Mailgun, SendGrid)
GLOBAL_ENV_SMTP_HOST=smtp.gmail.com
GLOBAL_ENV_SMTP_PORT=465
GLOBAL_ENV_SMTP_SECURE=true
GLOBAL_ENV_SMTP_USER=your_email@gmail.com
GLOBAL_ENV_SMTP_PASS=your_app_password
GLOBAL_ENV_SMTP_FROM=no-reply@yourdomain.com

# Option B: Resend API (Highly Recommended for production clouds)
GLOBAL_ENV_RESEND_API_KEY=re_your_api_key
GLOBAL_ENV_RESEND_FROM_EMAIL=no-reply@yourdomain.com

